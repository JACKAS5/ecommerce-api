{
  "name": "ecommerce-api",
  "version": "1.0.0",
  "description": "Scalable E-Commerce API built with Express and MongoDB",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "start": "cross-env NODE_ENV=production node src/server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "lint": "eslint . --ext .js,.mjs",
    "prepare": "husky install"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "coverageDirectory": "coverage"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ]
  },
  "keywords": [
    "ecommerce",
    "api",
    "express",
    "mongodb",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.2.4",
    "morgan": "^1.10.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-jest": "^30.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^10.0.2",
    "husky": "^8.0.3",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.2",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}